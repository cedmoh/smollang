// TODO: Add support for NEWLINES in more places, like after statements and between statements in blocks.

program   =  { SOI ~ body ~ EOI }
body      = _{ (NEWLINE | statement)* }
statement = _{ directive | expression }

// Keywords
// directives
use  = _{ "use" }
from = _{ "from" }
// declarations
var = @{ "var" }
val = @{ "val" }
fn  = _{ "fn" }
// control flow
do    = _{ "do" }
end   = _{ "end" }
ret   = _{ "ret" }
loop  = _{ "loop" }
br    = _{ "br" }
cont  = _{ "cont" }
if    = _{ "if" }
elsif = _{ "elsif" }
else  = _{ "else" }
match = _{ "match" }
then  = _{ "then" }
// literals
true  = @{ "true" }
false = @{ "false" }
not   = @{ "not" }
nil   = @{ "nil" }
// ops
set     =  { "set" }
gte     =  { "gte" }
gt      =  { "gt" }
lte     =  { "lte" }
lt      =  { "lt" }
eq      =  { "eq" }
neq     =  { "neq" }
and     =  { "and" }
or      =  { "or" }
to      =  { "to" }
til     =  { "til" }
keyword = _{
  
  | use
  | from
  | var
  | val
  | fn
  | do
  | end
  | ret
  | loop
  | br
  | cont
  | if
  | elsif
  | else
  | match
  | then
  | true
  | false
  | not
  | nil
  | set
  | gte
  | gt
  | lte
  | lt
  | eq
  | neq
  | and
  | or
  | til
  | to
}

// Operators
addition                  = @{ "+" }
addition_assignment       = @{ "+=" }
subtraction               = @{ "-" }
subtraction_assignment    = @{ "-=" }
multiplication            = @{ "*" }
multiplication_assignment = @{ "*=" }
division                  = @{ "/" }
division_assignment       = @{ "/=" }
exponent                  = @{ "^" }
exponent_assignment       = @{ "^=" }
modulo                    = @{ "%" }
modulo_assignment         = @{ "%=" }
greater_than_or_equals    = @{ ">=" | gte }
greater_than              = @{ ">" | gt }
less_than_or_equals       = @{ "<=" | lte }
less_than                 = @{ "<" | lt }
equals                    = @{ "==" | eq }
not_equals                = @{ "!=" | neq }
logic_and                 = @{ "&&" | and }
logic_and_assignment      = @{ "&&=" }
logic_or                  = @{ "||" | or }
logic_or_assignment       = @{ "||=" }
range_inclusive           = @{ "..=" }
range                     = @{ ".." }
assignment_set_symbol     = _{ "=" | set }
pipe_to_symbol            = _{ "|>" | to }
then_check_symbol         = _{ "?" | then }
then_else_symbol          = _{ ":" | else }
match_check_symbol        = _{ "~=" | match }
match_arm_symbol          = _{ "->" | do }
match_separator_symbol    = _{ "," }
operator                  = _{
  
  | range_inclusive
  | range
  | logic_and_assignment
  | logic_and
  | logic_or_assignment
  | logic_or
  | equals
  | not_equals
  | greater_than_or_equals
  | greater_than
  | less_than_or_equals
  | less_than
  | addition_assignment
  | subtraction_assignment
  | multiplication_assignment
  | division_assignment
  | exponent_assignment
  | modulo_assignment
  | addition
  | subtraction
  | multiplication
  | division
  | exponent
  | modulo
}

// Directives
directive = { use_directive }

// Use
use_directive = { use ~ use_imports ~ from ~ use_path }
use_imports   = { (identifier ~ ",")* ~ identifier }
// TODO: figure import paths out
use_path = { identifier | string_literal }

// Expressions
// TODO: Left-factor optimization to avoid backtracking. e.g:
// expression = { primary ~ expression_tail? }
// expression_tail = { assignment_tail | pipe_tail | operation_tail | then_tail }
expression = {
  
  | declaration
  | loop_expression
  | returned_expression
  | broken_expression
  | continue_expression
  | then_expression
  | pipe_expression
  | assignment_expression
  | operation
  | match_expression
  | member
  | call
  | literal
  | block
  | identifier
}

dynamic_key_expression = _{ "(" ~ expression ~ ")" }

// Operation
operation = { operand ~ (operator ~ operand)+ }
operand   = {
    // every expression except operation, then_expression, pipe_expression, and declaration
  
  | assignment_expression
  | match_expression
  | member
  | call
  | identifier
  | literal
  | dynamic_key_expression
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}

continue_expression = { cont }
broken_expression   = { br ~ expression? }
returned_expression = { ret ~ expression? }

// Assignment
assignment_expression      = { assignment_left_hand_side ~ assignment_set_symbol ~ assignment_right_hand_side }
assignment_left_hand_side  = { identifier }
assignment_right_hand_side = { expression }

// Member
member                  = { member_segment ~ (member_infix_operator ~ member_segment)+ ~ member_postfix_operator? }
member_segment          = { block | literal | identifier }
member_infix_operator   = { member_dot | member_call }
member_dot              = { "." }
member_call             = { call_arguments ~ "." }
member_postfix_operator = { member_call_postfix }
member_call_postfix     = { call_arguments }

// Call
call                          =  { callee ~ call_generics? ~ call_arguments }
call_generics                 =  { "<" ~ call_generic_parameter+ ~ ">" }
call_generic_parameter        =  { identifier }
callee                        =  { block | identifier }
call_arguments                =  { call_arguments_empty | call_arguments_in_parenthesis | call_arguments_naked }
call_arguments_empty          = _{ "(" ~ ")" }
call_arguments_in_parenthesis = _{ "(" ~ expression ~ ("," ~ expression)* ~ ")" }
call_arguments_naked          = _{ expression_in_call ~ ("," ~ expression_in_call)* }
expression_in_call            = _{
  
  | declaration
  | assignment_expression
  | loop_expression
  | match_expression
  | call
  | literal
  | dynamic_key_expression
  | identifier
}

// Pipe
pipe_expression                 =  { pipe_first_arm ~ (NLS ~ pipe_to_symbol ~ pipe_arm)+ }
pipe_shared_allowed_expressions = _{
    // every expression except pipe_expression and operation
  
  | declaration
  | returned_expression
  | broken_expression
  | continue_expression
  | then_expression
  | assignment_expression
  | match_expression
  | member
  | call
  | literal
  | block
  | identifier
}
pipe_first_arm                  =  { pipe_shared_allowed_expressions }
pipe_arm                        =  { operation | pipe_shared_allowed_expressions }

// Declaration
declaration = _{ variable_declaration | function_declaration }

// Identifiers
identifier = @{ !(number_literal | (keyword ~ !ASCII_ALPHANUMERIC)) ~ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

// Blocks
block = { "(" ~ NLS ~ (expression ~ NLS)* ~ ")" }

function_declaration = { function_name? ~ function_arguments ~ function_body? }
function_name        = { identifier }
function_arguments   = { "|" ~ (function_argument)? ~ ("," ~ function_argument)* ~ "|" }
function_argument    = { identifier }
function_body        = { expression }

// Variables
variable_declaration    = { variable_name ~ ((val ~ variable_initialization) | (var ~ variable_initialization?)) }
variable_initialization = { expression }
// TODO: support patterns
variable_name = @{ identifier }

// Literals
literal          =  {
  
  | nil_literal
  | array_literal
  | object_literal
  | boolean_literal
  | string_literal
  | template_literal
  | number_literal
  | hexadecimal_literal
}
nil_literal      =  { nil }
string_literal   = @{ "'" ~ string_text ~ "'" }
string_text      = ${ ('\u{00}'..'\u{26}' | '\u{28}'..'\u{10FFFF}')* }
template_literal = @{ "$" ~ "'" ~ string_text ~ "'" }
// any ascii character except for ' (single quote)
number_literal = _{
  
  | decimal_literal
  | integer_literal
  | binary_literal
  | octal_literal
  | hexadecimal_literal
}

// the negation in the end is to protect against cases like `1..3` and `1.abs`
integer_literal     = @{ "-"? ~ (ASCII_DIGIT | "_")+ }
decimal_literal     = @{ "-"? ~ (ASCII_DIGIT | "_")+ ~ "." ~ (ASCII_DIGIT | "_")* ~ !("." | ASCII_ALPHA) }
hexadecimal_literal = @{ "#" ~ (ASCII_HEX_DIGIT | "_")+ }
binary_literal      = @{ "b" ~ (ASCII_BIN_DIGIT | "_")+ }
octal_literal       = @{ "o" ~ (ASCII_OCT_DIGIT | "_")+ }
boolean_literal     = @{ true | false }
array_literal       =  { "[" ~ NLS ~ array_entries ~ NLS ~ "]" }
array_entries       =  { array_entry? ~ ("," ~ NLS ~ array_entry)* ~ ","? }
array_entry         =  { expression }
object_literal      =  { "{" ~ NLS ~ object_entries ~ NLS ~ "}" }
object_entries      =  { object_entry? ~ ("," ~ NLS ~ object_entry)* ~ ","? }
object_entry        =  { object_key ~ object_value }
object_key          =  { identifier | literal | dynamic_key_expression }
object_value        =  { expression }

// Then
then_expression = { then_condition ~ then_check_symbol ~ then_body ~ (then_else_symbol ~ then_else_body)? }
then_condition  = {
    // everything except then_expression
  
  | operation
  | declaration
  | returned_expression
  | broken_expression
  | continue_expression
  | assignment_expression
  | operation
  | match_expression
  | member
  | call
  | literal
  | block
  | identifier
}
then_body       = { expression }
then_else_body  = { expression }

// Pattern
pattern               = {
  
  | array_pattern
  | destructuring_pattern
  | tuple_pattern
  | variable_pattern
}
wildcard              = { "_" }
rest                  = { ".." }
rest_term             = { rest ~ identifier? }
pattern_term          = { wildcard | identifier | literal | rest_term }
variable_pattern      = { pattern_term }
tuple_pattern         = { (pattern_term) ~ ("," ~ pattern_term)+ }
array_pattern         = { "[" ~ (pattern_term | rest_term)? ~ ("," ~ (pattern_term | rest_term))* ~ "]" }
destructuring_pattern = { "{" ~ (pattern_term | rest_term) ~ ("," ~ (pattern_term | rest_term))+ ~ "}" }

// Match
match_expression =  { match_term ~ match_check_symbol ~ match_arms }
match_term       =  {
    // everything except match_expression, then_expression and operation
  
  | declaration
  | returned_expression
  | broken_expression
  | continue_expression
  | assignment_expression
  | member
  | call
  | literal
  | block
  | identifier
}
match_arms       = _{ (NLS ~ match_arm ~ match_separator_symbol?)+ }
match_arm        =  { pattern ~ match_arm_symbol ~ expression }

// Loop
loop_expression = { loop ~ loop_body }
loop_body       = { expression }

// Comments
COMMENT                = _{ !hexadecimal_literal ~ (multiline_comment | inline_comment | single_comment) }
single_comment_body    =  { (!NEWLINE ~ ANY)* }
single_comment         =  { "#" ~ single_comment_body? }
multiline_comment_body =  { (!"###" ~ ANY)* }
multiline_comment      =  { "###" ~ multiline_comment_body ~ "###" }
inline_comment_body    =  { (!"##" ~ ANY)* }
inline_comment         =  { "##" ~ inline_comment_body? ~ "##" }

WHITESPACE = _{ " " }

NLS = _{ NEWLINE* }
