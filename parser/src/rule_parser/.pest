program =  { SOI ~ body ~ EOI }
body    = _{ expressions? }

// Keywords
// declarations
var = @{ "var" }
val = @{ "val" }
fn  = _{ "fn" }
// control flow
do    = _{ "do" }
end   = _{ "end" }
ret   = _{ "ret" }
for   = _{ "for" }
in    = _{ "in" }
while = _{ "while" }
loop  = _{ "loop" }
br    = _{ "br" }
cont  = _{ "cont" }
if    = _{ "if" }
elsif = _{ "elsif" }
else  = _{ "else" }
match = _{ "match" }
then  = _{ "then" }
// literals
true  = @{ "true" }
false = @{ "false" }
not   = @{ "not" }
nil   = @{ "nil" }
// ops
set     = { "set" }
gte     = { "gte" }
gt      = { "gt" }
lte     = { "lte" }
lt      = { "lt" }
eq      = { "eq" }
neq     = { "neq" }
and     = { "and" }
or      = { "or" }
to      = { "to" }
til     = { "til" }
keyword = {
  
  | var
  | val
  | fn
  | do
  | end
  | ret
  | for
  | in
  | while
  | loop
  | br
  | cont
  | if
  | elsif
  | else
  | match
  | then
  | true
  | false
  | not
  | nil
  | set
  | gte
  | gt
  | lte
  | lt
  | eq
  | neq
  | and
  | or
  | til
  | to
}

// Operators
addition               = @{ "+" }
subtraction            = @{ "-" }
multiplication         = @{ "*" }
division               = @{ "/" }
exponent               = @{ "^" }
modulo                 = @{ "%" }
greater_than_or_equals = @{ ">=" | gte }
greater_than           = @{ ">" | gt }
less_than_or_equals    = @{ "<=" | lte }
less_than              = @{ "<" | lt }
equals                 = @{ "==" | eq }
not_equals             = @{ "!=" | neq }
logic_and              = @{ "&&" | and }
logic_or               = @{ "||" | or }
range_inclusive        = @{ "..=" }
range                  = @{ ".." }
assignment_set_symbol  = _{ "=" | set }
pipe_to_symbol         = _{ "|>" | to }
then_check_symbol      = _{ "?" | then }
then_else_symbol       = _{ ":" | else }
match_check_symbol     = _{ "~=" | match }
match_arm_symbol       = _{ "->" | do }
match_separator_symbol = _{ "," }
operator               = _{
  
  | addition
  | subtraction
  | multiplication
  | division
  | exponent
  | modulo
  | greater_than_or_equals
  | greater_than
  | less_than_or_equals
  | less_than
  | equals
  | not_equals
  | logic_and
  | logic_or
  | range_inclusive
  | range
}

// Expressions
expressions            = _{ (newlines ~ expression ~ newlines)+ }
expression             =  {
  
  | then_expression
  | pipe_expression
  | operation
  | assignment_expression
  | declaration
  | match_expression
  | call
  | member
  | identifier
  | literal
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}
dynamic_key_expression = _{ "(" ~ expression ~ ")" }

// Operation
operation = { operand ~ (operator ~ operand)+ }
operand   = {
    // every expression except operation
  
  | then_expression
  | pipe_expression
  | assignment_expression
  | declaration
  | match_expression
  | call
  | member
  | identifier
  | literal
  | dynamic_key_expression
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}

continue_expression = { cont }
broken_expression   = { br ~ expression? }
returned_expression = { ret ~ expression? }

// Assignment
assignment_expression      = { assignment_left_hand_side ~ newlines ~ assignment_set_symbol ~ newlines ~ assignment_right_hand_side }
assignment_left_hand_side  = { identifier }
assignment_right_hand_side = { expression }

// Member
member         = { (member_segment ~ newlines ~ "." ~ newlines)+ ~ member_segment }
member_segment = {
    // every expression except member and operation
  
  | call
  | identifier
  | literal
  | dynamic_key_expression
}

// Pipe
pipe_expression                 =  { pipe_first_arm ~ (newlines ~ pipe_to_symbol ~ newlines ~ pipe_arm)+ }
pipe_shared_allowed_expressions = _{
    // every expression except pipe_expression and operation
  
  | then_expression
  | assignment_expression
  | declaration
  | match_expression
  | call
  | member
  | identifier
  | literal
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}
pipe_first_arm                  =  { pipe_shared_allowed_expressions }
pipe_arm                        =  { operation | pipe_shared_allowed_expressions }

// Call
call                          =  { callee ~ call_generics? ~ call_arguments }
call_generics                 =  { "<" ~ call_generic_parameter+ ~ ">" }
call_generic_parameter        =  { identifier }
callee                        =  { identifier }
call_arguments                =  { call_arguments_empty | call_arguments_in_parenthesis | call_arguments_naked }
call_arguments_empty          = _{ "(" ~ newlines ~ ")" }
call_arguments_in_parenthesis = _{ "(" ~ newlines ~ expression ~ newlines ~ (newlines ~ "," ~ newlines ~ expression)* ~ newlines ~ ")" }
call_arguments_naked          = _{ expression_in_call ~ (newlines ~ "," ~ newlines ~ expression_in_call)* }
expression_in_call            = _{
  
  | assignment_expression
  | declaration
  | loop_flow
  | while_flow
  | for_flow
  | if_chain
  | match_expression
  | call
  | member
  | identifier
  | literal
  | dynamic_key_expression
}

// Declaration
declaration = _{ variable_declaration | function_declaration }

// Identifiers
identifier = @{ !(number_literal | (keyword ~ !ASCII_ALPHANUMERIC)) ~ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

// Blocks
block         =  { "(" ~ newlines ~ block_content ~ newlines ~ ")" }
block_content = _{ (expression ~ newlines)* }

function_declaration = { function_name? ~ function_arguments ~ function_body? }
function_name        = { identifier }
function_arguments   = { "|" ~ (function_argument)? ~ ("," ~ function_argument)* ~ "|" }
function_argument    = { identifier }
function_body        = { expression }

// Variables
variable_declaration    =  { variable_name ~ ((val ~ variable_initialization) | (var ~ variable_initialization?)) }
variable_initialization =  { newlines ~ expression }
variable_name           = @{ identifier }

// Literals
literal        =  {
  
  | nil_literal
  | array_literal
  | object_literal
  | boolean_literal
  | string_literal
  | number_literal
  | hexadecimal_literal
}
nil_literal    =  { nil }
string_literal = @{ "'" ~ string_text ~ "'" }
string_text    = ${ ('\u{00}'..'\u{26}' | '\u{28}'..'\u{10FFFF}')* }
// any ascii character except for ' (single quote)
number_literal = _{
  
  | decimal_literal
  | integer_literal
  | binary_literal
  | octal_literal
  | hexadecimal_literal
}
// the negation in the end is to protect against cases like `1..3` and `1.abs`
integer_literal     = { "-"? ~ (ASCII_DIGIT | "_")+ }
decimal_literal     = { "-"? ~ (ASCII_DIGIT | "_")+ ~ "." ~ (ASCII_DIGIT | "_")* ~ !("." | ASCII_ALPHA) }
hexadecimal_literal = { "#" ~ ('a'..'f' | 'A'..'F' | ASCII_DIGIT | "_")+ }
binary_literal      = { "b" ~ ('0'..'1' | "_")+ }
octal_literal       = { "o" ~ ('0'..'7' | "_")+ }
boolean_literal     = { true | false }
array_literal       = { "[" ~ newlines ~ array_entries ~ newlines ~ "]" }
array_entries       = { array_entry? ~ (newlines ~ "," ~ newlines ~ array_entry)* ~ newlines ~ ","? }
array_entry         = { expression }
object_literal      = { "{" ~ newlines ~ object_entries ~ newlines ~ "}" }
object_entries      = { object_entry? ~ (newlines ~ "," ~ newlines ~ object_entry)* ~ newlines ~ ","? }
object_entry        = { object_key ~ object_value }
object_key          = { identifier | literal | dynamic_key_expression }
object_value        = { expression }

// Then
then_expression       = { then_condition ~ then_check_symbol ~ then_body ~ (then_else_symbol ~ then_else_body)? }
then_condition        = { then_first_expression }
then_body             = { expression }
then_else_body        = { expression }
then_first_expression = {
    // everything except then_expression and operation
  
  | assignment_expression
  | declaration
  | match_expression
  | call
  | member
  | identifier
  | literal
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}

// If
if_chain        = { if_segment ~ newlines ~ (elsif_segment ~ newlines)* ~ else_segment? }
if_condition    = { "("? ~ expression ~ ")"? }
if_segment      = { if ~ if_condition ~ newlines ~ do? ~ newlines ~ if_body }
if_body         = { expression }
elsif_segment   = { elsif ~ if_condition ~ newlines ~ do? ~ newlines ~ elsif_body }
elsif_condition = { "("? ~ expression ~ ")"? }
elsif_body      = { expression }
else_segment    = { else ~ newlines ~ else_body }
else_body       = { expression }

// Pattern
pattern               = {
  
  | array_pattern
  | destructuring_pattern
  | tuple_pattern
  | variable_pattern
}
wildcard              = { "_" }
rest                  = { ".." }
rest_term             = { rest ~ identifier? }
pattern_term          = { identifier | literal | wildcard | rest_term }
variable_pattern      = { pattern_term }
tuple_pattern         = { (pattern_term) ~ ("," ~ pattern_term)+ }
array_pattern         = { "[" ~ (pattern_term | rest_term) ~ ("," ~ (pattern_term | rest_term)) ~ "]" }
destructuring_pattern = { "{" ~ (pattern_term | rest_term) ~ ("," ~ (pattern_term | rest_term))+ ~ "}" }

// Match
match_expression =  { match_term ~ newlines ~ match_check_symbol ~ newlines ~ match_arms }
match_term       =  {
    // everything except match_expression, then_expression and operation
  
  | assignment_expression
  | declaration
  | call
  | member
  | identifier
  | literal
  | returned_expression
  | broken_expression
  | continue_expression
  | block
}
match_arms       = _{ (match_arm ~ newlines ~ match_separator_symbol? ~ newlines)+ }
match_arm        =  { pattern ~ newlines ~ match_arm_symbol ~ newlines ~ expression }

// Loop
loop_flow = { loop ~ newlines ~ loop_body }
loop_body = { expression }

// While
while_flow      = { while ~ newlines ~ while_condition ~ newlines ~ while_body }
while_condition = { expression }
while_body      = { expression }

// For
for_flow = { for ~ newlines ~ for_item ~ newlines ~ in ~ newlines ~ for_iter ~ newlines ~ for_body }
for_item = { identifier }
// TODO: should be pattern
for_iter = { expression }
for_body = { expression }

// Comments
COMMENT                = _{ !hexadecimal_literal ~ (multiline_comment | inline_comment | single_comment) ~ newlines }
single_comment_body    =  { (!NEWLINE ~ ANY)* }
single_comment         =  { !"###" ~ !"##" ~ "#" ~ single_comment_body? }
multiline_comment_body =  { (!"###" ~ ANY)* }
multiline_comment      =  { "###" ~ multiline_comment_body ~ "###" }
inline_comment_body    =  { (!"##" ~ ANY)* }
inline_comment         =  { "##" ~ inline_comment_body? ~ "##" }

WHITESPACE = _{ " " }

newlines = _{ (NEWLINE)* }
